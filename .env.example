# === Telegram (required) ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# === Database (Railway auto-injects) ===
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/railway

# === Redis (Railway auto-injects) ===
REDIS_URL=redis://default:pass@host:6379

# === Railway Storage Bucket ===
BUCKET_ENDPOINT=https://your-bucket.railway.app
BUCKET_ACCESS_KEY=your-access-key
BUCKET_SECRET_KEY=your-secret-key
BUCKET_NAME=file-bot

# === Optional tuning ===
# MAX_FILE_SIZE_GB=50
# MAX_CONCURRENT_DOWNLOADS=3
# MAX_CONCURRENT_TRANSMISSIONS=10
# ALLOWED_USERS=123456,789012
# ARQ_MAX_JOBS=8
# DATA_DIR=/data
